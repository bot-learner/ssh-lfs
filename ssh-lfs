#!/usr/bin/env bash
# ssh-lfs synchronizes files over SSH with rsync, using a local .ssh-lfs configuration.
#
# Run: ssh-lfs <push|pull> <host-name> [config-name]
#      ssh-lfs init <relative-path>
# - The directory in which the command is run (pwd) is both the local sync root
#   and the location from which push/pull loads .ssh-lfs/ configuration.
# - init creates <current-directory>/<relative-path>/.ssh-lfs/ with example files.
# - Every relative path in the manifest maps to both sides:
#     local:  <current-directory>/<relative-path>
#     remote: <REMOTE_BASE>/<relative-path>
#
# This script requires bash, ssh, and rsync. SSH key authentication is recommended
# so that synchronization does not repeatedly request a password.
set -euo pipefail

PROGRAM_NAME=${0##*/}

usage() {
  # Keep argument errors brief; see readme.md for full details.
  cat <<EOF
Usage: $PROGRAM_NAME <push|pull> <host-name> [config-name]
       $PROGRAM_NAME init <relative-path>

Host configuration: .ssh-lfs/hosts/<host-name>.host
Sync configuration:  .ssh-lfs/lfs-config/<config-name>.config
                    (default: ssh-lfs)
EOF
}

fail() {
  # Send all errors to stderr and terminate the script consistently.
  printf '%s: %s\n' "$PROGRAM_NAME" "$*" >&2
  exit 1
}

trim() {
  # Configuration permits surrounding whitespace; remove it after reading a value.
  local value=$1
  value=${value#"${value%%[![:space:]]*}"}
  value=${value%"${value##*[![:space:]]}"}
  printf '%s' "$value"
}

# A sync manifest and init target must remain below the current working directory.
# Paths such as ../other-project and /tmp/project are rejected to prevent accidental
# reads or writes outside the intended local project.
is_safe_relative_path() {
  local path=$1
  [[ -n $path && $path != /* && $path != .. && $path != ../* && $path != */../* && $path != */.. ]]
}

if [[ ${1-} == init ]]; then
  [[ $# -eq 2 ]] || { usage >&2; exit 2; }
else
  [[ $# -eq 2 || $# -eq 3 ]] || { usage >&2; exit 2; }
fi
direction=$1
# The current directory intentionally provides both the local base and the project
# configuration. This is important when ssh-lfs is installed in ~/.local/bin.
local_base=$(pwd -P)

if [[ $direction == init ]]; then
  init_relative_path=$2
  is_safe_relative_path "$init_relative_path" || fail "init requires a safe relative path"
  # Keep the displayed target path clean for the common `init .` form.
  if [[ $init_relative_path == . ]]; then
    init_root=$local_base
  else
    init_root=$local_base/${init_relative_path#./}
  fi
  init_config_dir=$init_root/.ssh-lfs
  # Existing configuration may contain user-specific host details. Never overwrite
  # it, even partially: report that initialization has already been completed.
  if [[ -e $init_config_dir ]]; then
    printf 'ssh-lfs is already initialized: %s\n' "$init_config_dir"
    exit 0
  fi

  # mkdir -p also permits initializing a new project directory in one command.
  mkdir -p -- "$init_config_dir/hosts" "$init_config_dir/lfs-config"
  cat > "$init_config_dir/hosts/ffu-ssh-example.host" <<'EOF'
# Example with all SSH connection details defined in this file.
SSH_HOST=server.example.com
SSH_USER=deploy
SSH_PORT=22
REMOTE_BASE=/srv/ssh-lfs
EOF
  cat > "$init_config_dir/hosts/ssh-alias-example.host" <<'EOF'
# Example using an alias defined in ~/.ssh/config.
# Replace example-server with an actual SSH Host alias.
SSH_HOST=example-server
REMOTE_BASE=/srv/example/ssh-lfs
EOF
  # Every manifest line is commented deliberately. Users must explicitly choose
  # which files or directories should be synchronized before the first transfer.
  cat > "$init_config_dir/lfs-config/ssh-lfs.config" <<'EOF'
# Each non-comment line defines one relative path to synchronize.
# The local base is the directory from which ssh-lfs is invoked.
# The remote base is REMOTE_BASE in the selected host configuration.
# For example, example_data/ maps to REMOTE_BASE/example_data/ on the remote host.
# A trailing / follows standard rsync directory semantics.

# example_data/
# .env
EOF
  printf 'Initialized ssh-lfs configuration: %s\n' "$init_config_dir"
  exit 0
fi

host_name=$2
config_name=${3:-ssh-lfs}
case $direction in push|pull) ;; *) usage >&2; exit 2 ;; esac

config_dir=$local_base/.ssh-lfs
[[ $config_name =~ ^[A-Za-z0-9._-]+$ ]] || fail "Invalid config name: $config_name"
# Accept either `ssh-lfs-l` or the explicit filename `ssh-lfs-l.config`.
if [[ $config_name == *.config ]]; then
  manifest=$config_dir/lfs-config/$config_name
else
  manifest=$config_dir/lfs-config/$config_name.config
fi

# The host name becomes part of a file path, so only ordinary filename characters
# are allowed. This prevents a parameter from addressing files outside hosts/.
[[ $host_name =~ ^[A-Za-z0-9._-]+$ ]] || fail "Invalid host name: $host_name"
host_config=$config_dir/hosts/$host_name.host
[[ -f $manifest ]] || fail "Sync manifest not found: $manifest"
[[ -f $host_config ]] || fail "Host configuration not found: $host_config"

# Host configuration is never sourced: source could execute arbitrary shell code.
# Only the KEY=VALUE fields below are accepted; blank lines and # comments are skipped.
# SSH_PORT is optional. When omitted, SSH uses the matching entry in ~/.ssh/config
# (or its own default port) without an overriding -p option.
SSH_HOST=
SSH_USER=
SSH_PORT=
REMOTE_BASE=
while IFS= read -r raw_line || [[ -n $raw_line ]]; do
  line=$(trim "$raw_line")
  [[ -z $line || $line == \#* ]] && continue
  [[ $line == *=* ]] || fail "Invalid line in $host_config: $raw_line"
  key=$(trim "${line%%=*}")
  value=$(trim "${line#*=}")
  case $key in
    SSH_HOST) SSH_HOST=$value ;;
    SSH_USER) SSH_USER=$value ;;
    SSH_PORT) SSH_PORT=$value ;;
    REMOTE_BASE) REMOTE_BASE=$value ;;
    *) fail "Unsupported key in $host_config: $key" ;;
  esac
done < "$host_config"

[[ -n $SSH_HOST && -n $REMOTE_BASE ]] || fail "$host_config must define SSH_HOST and REMOTE_BASE"
[[ -z $SSH_PORT || $SSH_PORT =~ ^[0-9]+$ ]] || fail "SSH_PORT must be a port number"
remote_target=$SSH_HOST
[[ -n $SSH_USER ]] && remote_target=$SSH_USER@$SSH_HOST
# Keep SSH options in an array so an omitted SSH_PORT does not override the user's
# ~/.ssh/config. The same options are used for mkdir and for rsync's transport.
ssh_options=()
[[ -n $SSH_PORT ]] && ssh_options=(-p "$SSH_PORT")

# Create the remote base before transferring. Invalid host, port, user, or
# authentication settings fail here instead of later with a less clear rsync error.
ssh "${ssh_options[@]}" -- "$remote_target" "mkdir -p -- $(printf '%q' "$REMOTE_BASE")"

line_number=0
while IFS= read -r raw_line || [[ -n $raw_line ]]; do
  line_number=$((line_number + 1))
  line=$(trim "$raw_line")
  [[ -z $line || $line == \#* ]] && continue
  # One manifest line represents one relative path, used unchanged on both sides.
  relative_path=$line
  # Disallow absolute paths and .. directory traversal. This keeps the remote path
  # inside REMOTE_BASE and prevents pull from writing outside the current directory.
  # Ordinary names containing ".." (for example, a..b) remain valid.
  is_safe_relative_path "$relative_path" \
    || fail "Line $line_number in $manifest must be a safe relative path"

  # Form the two absolute paths by appending the same relative path to each base.
  local_absolute=$local_base/$relative_path
  remote_absolute=$REMOTE_BASE/$relative_path
  if [[ $direction == push ]]; then
    # push only accepts an existing local item. Create its remote parent, then transfer.
    # rsync -a recursively preserves common attributes; --protect-args handles spaces.
    [[ -e $local_absolute || -L $local_absolute ]] || fail "Local path not found: $relative_path"
    # Show the resolved remote absolute path, not only the manifest-relative path.
    printf 'push  %s -> %s:%s\n' "$relative_path" "$host_name" "$remote_absolute"
    # This command runs inside the manifest-reading loop. -n prevents ssh from
    # consuming subsequent manifest lines through the loop's standard input.
    ssh -n "${ssh_options[@]}" -- "$remote_target" "mkdir -p -- $(printf '%q' "$(dirname -- "$remote_absolute")")"
    # -h prints human-readable sizes; progress2 reports progress for the complete
    # transfer rather than resetting for every individual file. rsync also receives
    # /dev/null as stdin so it cannot consume manifest lines.
    rsync -ah --info=progress2 --protect-args -e "ssh${SSH_PORT:+ -p $SSH_PORT}" -- "$local_absolute" "$remote_target:$remote_absolute" </dev/null
  else
    # pull reverses that direction: create the local parent, then fetch the same mapping.
    # If the remote item does not exist, rsync returns non-zero and set -e stops the script.
    printf 'pull  %s:%s -> %s\n' "$host_name" "$remote_absolute" "$relative_path"
    mkdir -p -- "$(dirname -- "$local_absolute")"
    rsync -ah --info=progress2 --protect-args -e "ssh${SSH_PORT:+ -p $SSH_PORT}" -- "$remote_target:$remote_absolute" "$local_absolute" </dev/null
  fi
done < "$manifest"
